@model List<StudentVM>


    <h1>Students</h1>
    @* <a class="btn btn-outline-primary" asp-action="Create">Create</a> *@
    <table class="table">
        <thead>
            <tr>
                <th></th>
                <th>@Html.DisplayNameFor(Model=>Model[0].FullName)</th>
                <th>@Html.DisplayNameFor(Model=>Model[0].Age)</th>
                <th>@Html.DisplayNameFor(Model=>Model[0].Email)</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
        @foreach(var student in Model)
        {
           <tr>
               <td></td>
                <td>@student.FullName</td>
            <td>@student.Age</td>
            <td>@student.Email</td>
            <td>

              <a class="btn btn-outline-primary" asp-action="GetStudentById" asp-route-id="@student.Id">Details (by route)</a>
                    <a class="btn btn-outline-secondary" asp-action="GetStudentByIdWithQuery" asp-route-id="@student.Id">Details (by query)</a>

                    <a class="btn btn-outline-info" 
                        asp-action="GetStudentFilter"
                        asp-route-age="@student.Age"
                        asp-route-fullname="@student.FullName">
                            Details by name and age</a>
            </td>
           </tr>

        }
        </tbody>
    </table>