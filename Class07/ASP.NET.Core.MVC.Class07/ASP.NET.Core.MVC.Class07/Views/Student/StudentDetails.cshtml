@model StudentDetailsViewModel


<h1>Student Details</h1>


<div>
    <dl class="row">
        <dt class="col-sm-2">Full name</dt>
        <dd class="col-sm-10">@Model.FullName</dd>

        <dt class="col-sm-2">Age</dt>
        <dd class="col-sm-10">@Model.Age</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Phone number</dt>
        <dd class="col-sm-10">@Model.Phone</dd>
    </dl>
</div>
<div>
    <a class="btn btn-outline-primary" asp-action="Index" asp-controller="Student">Back to List</a>
</div>