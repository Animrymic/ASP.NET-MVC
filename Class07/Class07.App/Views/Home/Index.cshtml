@model List<Class07.App.Models.ViewModel.StudentVM>

<h1>Students</h1>

@* Create/guard the UI when model is null or empty *@
@if (Model == null || !Model.Any())
{
    <p>No students found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(m => m[0].FullName)</th>
                <th>@Html.DisplayNameFor(m => m[0].Age)</th>
                <th>@Html.DisplayNameFor(m => m[0].Email)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.FullName</td>
                    <td>@student.Age</td>
                    <td>@student.Email</td>
                </tr>
            }
        </tbody>
    </table>
}
